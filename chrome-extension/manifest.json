{
  "manifest_version": 3,
  "name": "InbXr Signal Score",
  "short_name": "InbXr",
  "version": "1.0.0",
  "description": "Check the deliverability Signal Score of any sending domain in 30 seconds. Right-click any page or paste a domain in the popup.",
  "author": "InbXr",
  "homepage_url": "https://inbxr.us",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "Check Signal Score",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://inbxr.us/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
